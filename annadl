#! /usr/bin/env python3
import argparse
import json
import logging
import os
import re
import shutil
import sys
import subprocess
import time
from pathlib import Path
from urllib.parse import quote

from selenium import webdriver
from selenium.common.exceptions import NoSuchElementException
from selenium.webdriver.chrome.options import Options
from selenium.webdriver.chrome.service import Service as ChromeService
from selenium.webdriver.common.by import By
from webdriver_manager.chrome import ChromeDriverManager

C_DIR = os.path.dirname(os.path.realpath(__file__))
DL_PATH = os.path.join(C_DIR, "assets")
SEARCH_URLS = ["https://annas-archive.gl"]

config_path = Path(C_DIR) / "config.json"
if config_path.is_file():
    with config_path.open() as config_file:
        config = json.load(config_file)

    download_path = config.get("download_path", "")
    if download_path:
        DL_PATH = download_path.strip()

    configured_urls = config.get("search_urls", SEARCH_URLS)
    if isinstance(configured_urls, list):
        SEARCH_URLS = [str(url).strip().rstrip("/")
                       for url in configured_urls if str(url).strip()]
    elif isinstance(configured_urls, str) and configured_urls.strip():
        SEARCH_URLS = [configured_urls.strip().rstrip("/")]

if not SEARCH_URLS:
    raise SystemExit("config.json must contain at least one search URL")


def dlwait(path):
    """Wait until Chromium finishes downloading a file."""
    start_time = time.time()
    while any(name.endswith(".crdownload") for name in os.listdir(path)):
        time.sleep(1)
    return str(round(time.time() - start_time, 4))


def chrome_options(binary=None):
    options = Options()
    if binary:
        options.binary_location = binary
    options.add_argument("--headless")
    options.add_argument("--disable-extensions")
    options.add_argument("--no-sandbox")
    options.add_argument("--disable-dev-shm-usage")
    options.add_argument("--disable-gpu")
    options.add_argument("--disable-logging")
    options.add_argument("--log-level=3")
    options.add_argument("--silent")
    options.add_argument("--no-first-run")
    options.add_argument("--no-default-browser-check")
    options.add_argument("--remote-debugging-pipe")
    options.add_experimental_option("excludeSwitches", ["enable-logging"])
    options.add_experimental_option("useAutomationExtension", False)
    return options


def browser_version(binary):
    result = subprocess.run(
        [binary, "--version"], capture_output=True, text=True,
        timeout=5, check=True,
    )
    match = re.search(r"\b(\d+\.\d+\.\d+\.\d+)\b", result.stdout)
    if not match:
        raise RuntimeError(f"could not determine version from {result.stdout!r}")
    return match.group(1)


def start_browser():
    """Try each installed browser with a driver matching its exact version."""
    browser_names = (
        "google-chrome",
        "google-chrome-stable",
        "chromium",
        "chromium-browser",
    )
    browsers = []
    for name in browser_names:
        binary = shutil.which(name)
        if binary and binary not in browsers:
            browsers.append(binary)

    # Windows installations are commonly not added to PATH.
    windows_roots = (
        os.environ.get("PROGRAMFILES"),
        os.environ.get("PROGRAMFILES(X86)"),
        os.environ.get("LOCALAPPDATA"),
    )
    windows_paths = (
        "Google/Chrome/Application/chrome.exe",
        "Chromium/Application/chrome.exe",
        "Chromium/chrome.exe",
    )
    for root in windows_roots:
        if not root:
            continue
        for relative_path in windows_paths:
            binary = os.path.join(root, relative_path)
            if os.path.isfile(binary) and binary not in browsers:
                browsers.append(binary)

    errors = []
    os.environ["WDM_LOG_LEVEL"] = "0"
    os.environ["WDM_LOG"] = str(logging.NOTSET)
    os.environ.setdefault("WDM_LOCAL", "1")

    for binary in browsers:
        service = None
        try:
            version = browser_version(binary)
            driver_path = ChromeDriverManager(driver_version=version).install()
            service = ChromeService(driver_path)
            return webdriver.Chrome(
                service=service, options=chrome_options(binary)
            )
        except Exception as error:
            if service:
                service.stop()
            errors.append(f"{binary}: {error}")

    # Last resort: let Selenium Manager choose a driver if the exact-version
    # download is unavailable. This is intentionally after the exact matches
    # so a stale cached driver cannot be selected first.
    for binary in browsers:
        try:
            return webdriver.Chrome(options=chrome_options(binary))
        except Exception as error:
            errors.append(f"Selenium Manager/{binary}: {error}")

    print("Could not start Chrome or Chromium.")
    for error in errors:
        print(f"  {error}")
    print("Install Chrome or Chromium and rerun the command.")
    sys.exit(1)


def md5_for_url(url):
    match = re.search(r"(?<![0-9a-f])[0-9a-f]{32}(?![0-9a-f])",
                      url, re.IGNORECASE)
    return match.group(0).lower() if match else None


def search_results(driver, search, result_count, download_all):
    grouped = {}
    search_errors = []

    for base_url in SEARCH_URLS:
        try:
            start_url = f"{base_url}/search?q={quote(search)}"
            driver.get(start_url)
            time.sleep(2)
            driver.execute_script(
                "window.scrollTo(0, document.body.scrollHeight);"
            )
            time.sleep(1)

            links = driver.find_elements(
                By.CSS_SELECTOR, "a.js-vim-focus.custom-a"
            )
            print(f"{base_url}: found {len(links)} book links")

            for link in links:
                href = str(link.get_attribute("href") or "")
                if not href:
                    continue
                md5 = md5_for_url(href)
                key = md5 or href
                result = grouped.setdefault(
                    key,
                    {"md5": md5 or "unknown", "title": link.text.strip(),
                     "urls": []},
                )
                if not result["title"]:
                    result["title"] = link.text.strip()
                if href not in result["urls"]:
                    result["urls"].append(href)
        except Exception as error:
            search_errors.append((base_url, str(error)))
            print(f"{base_url}: search failed: {error}")

    results = list(grouped.values())
    if download_all or result_count == 0:
        selected_results = results
    else:
        selected_results = results[:result_count]
        if len(results) < result_count:
            print(f"Only {len(results)} unique results found")

    if search_errors:
        print("\nSearch sources that failed:")
        for url, error in search_errors:
            print(f"  {url}: {error}")

    for index, result in enumerate(selected_results, start=1):
        print(f"\n[{index}] {result['title']}")
        print(f"\tMD5: {result['md5']}")
        print(f"\tPossible download URLs: {len(result['urls'])}")

    return selected_results


def click_external_downloads(driver):
    selectors = (
        "//a[contains(text(), 'show external downloads')]",
        "//a[contains(text(), 'external downloads')]",
        "//button[contains(text(), 'show external downloads')]",
    )
    for selector in selectors:
        try:
            driver.find_element(By.XPATH, selector).click()
            return
        except NoSuchElementException:
            continue


def normalize_formats(values):
    formats = set()
    for value in values or []:
        for file_format in value.split(","):
            file_format = file_format.strip().lower().lstrip(".")
            if not file_format:
                continue
            if not re.fullmatch(r"[a-z0-9]+", file_format):
                raise ValueError(f"invalid download format: {file_format}")
            formats.add(file_format)
    return formats


def link_matches_formats(element, formats):
    if not formats:
        return True

    context = " ".join(
        (
            element.text,
            element.get_attribute("href") or "",
            element.find_element(By.XPATH, "..").text,
        )
    ).lower()
    return any(
        re.search(rf"(?<![a-z0-9])\.{re.escape(file_format)}(?![a-z0-9])",
                  context)
        or re.search(rf"(?<![a-z0-9]){re.escape(file_format)}(?![a-z0-9])",
                     context)
        for file_format in formats
    )


def download_from_source(driver, source_url, download_path, formats):
    driver.get(source_url)
    time.sleep(2)
    click_external_downloads(driver)
    time.sleep(2)

    page_text = driver.find_element(By.XPATH, "/html/body").text.lower()
    if "libgen" not in page_text:
        return False, "no LibGen download link was exposed"

    links = driver.find_elements(
        By.XPATH, "//a[contains(@href, 'libgen')]"
    )
    libgen_urls = [
        link.get_attribute("href") for link in links
        if link.get_attribute("href")
    ]
    if not libgen_urls:
        return False, "LibGen link was not found"

    for libgen_url in libgen_urls:
        try:
            driver.get(libgen_url)
            time.sleep(3)
            download_selectors = (
                "//a[contains(@href, 'get.php')]",
                "//a[contains(text(), 'GET')]",
                "//a[contains(@href, 'download')]",
            )
            candidates = []
            seen_links = set()
            for selector in download_selectors:
                for element in driver.find_elements(By.XPATH, selector):
                    link_key = (element.get_attribute("href"), element.text)
                    if link_key not in seen_links:
                        seen_links.add(link_key)
                        candidates.append(element)

            matching_candidates = [
                element for element in candidates
                if link_matches_formats(element, formats)
            ]
            if formats and not matching_candidates:
                continue

            for element in matching_candidates or candidates:
                try:
                    element.click()
                    dl_time = dlwait(download_path)
                    print(f"Successfully downloaded ({dl_time} seconds)")
                    return True, ""
                except Exception:
                    continue
        except Exception:
            continue

    if formats:
        requested = ", ".join(sorted(formats))
        return False, f"no matching download format found ({requested})"
    return False, "LibGen requires manual verification or its page changed"


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("path", metavar="path", type=str, default=DL_PATH,
                        nargs="?", help="A path for the download")
    parser.add_argument("--s", metavar="search", type=str, required=True,
                        help="A search query for the download")
    parser.add_argument("--n", metavar="quantity", type=int, default=5,
                        help="Number of unique results (0 means all)")
    parser.add_argument("--all", action="store_true",
                        help="Download every unique result returned")
    parser.add_argument("--format", action="append", dest="formats",
                        metavar="FORMAT",
                        help="Only download this format; repeat or comma-separate")
    args = parser.parse_args()

    try:
        formats = normalize_formats(args.formats)
    except ValueError as error:
        parser.error(str(error))

    os.makedirs(args.path, exist_ok=True)
    driver = start_browser()
    driver.command_executor.set_timeout(20)
    driver.set_page_load_timeout(20)
    driver.set_script_timeout(20)
    driver.command_executor._commands["send_command"] = (
        "POST", "/session/$sessionId/chromium/send_command"
    )
    driver.execute(
        "send_command",
        {"cmd": "Page.setDownloadBehavior",
         "params": {"behavior": "allow", "downloadPath": args.path}},
    )

    try:
        results = search_results(driver, args.s, args.n, args.all)
        if not results:
            print("No results found. Please check your search query.")
            return

        if args.all:
            selections = range(len(results))
        else:
            try:
                selection = int(input("\nEnter desired download: ")) - 1
            except ValueError:
                print("Invalid selection")
                return
            if selection < 0 or selection >= len(results):
                print("Invalid selection")
                return
            selections = [selection]

        failures = []
        for selection in selections:
            result = results[selection]
            print(f"\n[{selection + 1}] Downloading: {result['title']}")
            succeeded = False
            errors = []
            for source_url in result["urls"]:
                try:
                    succeeded, error = download_from_source(
                        driver, source_url, args.path, formats
                    )
                    if succeeded:
                        break
                    errors.append(f"{source_url}: {error}")
                except Exception as error:
                    errors.append(f"{source_url}: {error}")

            if not succeeded:
                failures.append((selection + 1, result["title"], errors))
                print("Download failed; continuing with the next result.")

        if failures:
            print("\nDownloads that failed:")
            for number, title, errors in failures:
                print(f"  [{number}] {title}")
                for error in errors:
                    print(f"    {error}")
        elif args.all:
            print("\nAll requested downloads completed successfully.")
    except KeyboardInterrupt:
        print("\nScript interrupted by user")
    finally:
        driver.quit()

if __name__ == "__main__":
    main()
